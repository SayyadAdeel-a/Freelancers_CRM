rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the document belongs to the user
    function isOwner(data) {
      return data.userId == request.auth.uid;
    }

    // Clients collection
    match /clients/{clientId} {
      function isValidClient(data) {
        return data.name is string && data.name.size() > 0;
      }

      allow read: if isAuthenticated() && isOwner(resource.data);
      allow create: if isAuthenticated() && 
                    isOwner(request.resource.data) &&
                    isValidClient(request.resource.data);
      allow update: if isAuthenticated() && 
                    isOwner(resource.data) &&
                    isOwner(request.resource.data) &&
                    isValidClient(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data);

      // Invoices subcollection
      match /invoices/{invoiceId} {
        allow read: if isAuthenticated() && isOwner(resource.data);
        allow create: if isAuthenticated() && isOwner(request.resource.data);
        allow update: if isAuthenticated() && isOwner(resource.data);
        allow delete: if isAuthenticated() && isOwner(resource.data);
      }
    }

    // Support for collectionGroup queries on invoices
    match /{path=**}/invoices/{invoiceId} {
      allow read: if isAuthenticated() && isOwner(resource.data);
    }

    // Notes collection
    match /notes/{noteId} {
      allow read: if isAuthenticated() && isOwner(resource.data);
      allow create: if isAuthenticated() && isOwner(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data);
    }

    // Reminders collection
    match /reminders/{reminderId} {
      allow read: if isAuthenticated() && isOwner(resource.data);
      allow create: if isAuthenticated() && isOwner(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data);
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
