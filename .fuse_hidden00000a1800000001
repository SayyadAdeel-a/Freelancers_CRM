#!/bin/bash

# Configuration
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

# Load environment
if [ -f "$SCRIPT_DIR/.env.claude" ]; then
    source "$SCRIPT_DIR/.env.claude"
fi

# Ensure mandatory variables are set
if [ -z "$OPENROUTER_API_KEY" ]; then
    echo -e "\x1b[31mError: OPENROUTER_API_KEY is not set in .env.claude\x1b[0m"
    exit 1
fi

# Stop any old proxy just in case
pkill -f or-proxy.js > /dev/null 2>&1

echo -e "\x1b[34mStarting Claude via OpenRouter Direct API...\x1b[0m"
echo -e "\x1b[32mModel: $ANTHROPIC_DEFAULT_SONNET_MODEL\x1b[0m"

# Run Claude with any passed arguments
claude "$@"
